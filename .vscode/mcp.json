{
    "servers": {
      "cowork-dispatch": {
        "type": "stdio",
        "command": "uv",
        "args": ["run", "--link-mode", "copy", "cowork-dispatch"],
        "envFile": "${workspaceFolder}/.env",
        "env": {
          "COWORK_WORKSPACE_ROOT": "${workspaceFolder}"
        }
      }
    }
  }